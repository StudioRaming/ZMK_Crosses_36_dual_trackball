#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/zmk/input_transform.h>
#include <input/processors.dtsi>
#include <input/processors/report_rate_limit.dtsi>
#include <behaviors/rate_limit.dtsi>
#include <physical_layouts.dtsi>


/ {
    chosen {
        zmk,kscan = &kscan0;
    };

    // 54-key (4x6 + 3 thumb per half) matrix transform (official Crosses 54)
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <5>;
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)       RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)       RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)       RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)       RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11)
                        RC(4,3) RC(4,4) RC(4,5)       RC(4,6) RC(4,7) RC(4,8)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "row2col";
        wakeup-source;

        // 5 rows: row0 = number row (added vs the 36 build)
        row-gpios
            = <&gpio0 24 GPIO_ACTIVE_HIGH>
            , <&gpio0 2 GPIO_ACTIVE_HIGH>
            , <&gpio0 29 GPIO_ACTIVE_HIGH>
            , <&gpio0 31 GPIO_ACTIVE_HIGH>
            , <&gpio0 11 GPIO_ACTIVE_HIGH>
            ;
    };

    behaviors {
        rrl {
            #binding-cells = <1>;
            values-ms = <8 6 4 2>;
        };
    };

    //left hand trackball
    split_inputs {
        #address-cells = <1>;
        #size-cells = <0>;

        trackball_peripheral_split: trackball_peripheral_split@0 {
            compatible = "zmk,input-split";
            reg = <0>;
        };
    };

    trackball_peripheral_listener: trackball_peripheral_listener {
        compatible = "zmk,input-listener";
        status = "disabled";
        device = <&trackball_peripheral_split>;
    };

    //right hand trackball
    trackball_central_listener: trackball_central_listener {
        compatible = "zmk,input-listener";
        status = "disabled";
    };

    // Physical layout required by ZMK Studio. 54 keys, order matches the
    // matrix-transform map / keymap binding order (official Crosses 54 layout).
    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Crosses 54";
        transform = <&default_transform>;
        keys  //                     w   h    x    y     rot   rx   ry
            = <&key_physical_attrs 100 100    0  112       0     0     0>
            , <&key_physical_attrs 100 100  100  112       0     0     0>
            , <&key_physical_attrs 100 100  200   62       0     0     0>
            , <&key_physical_attrs 100 100  300    0       0     0     0>
            , <&key_physical_attrs 100 100  400   25       0     0     0>
            , <&key_physical_attrs 100 100  500   38       0     0     0>
            , <&key_physical_attrs 100 100  912   38       0     0     0>
            , <&key_physical_attrs 100 100 1012   25       0     0     0>
            , <&key_physical_attrs 100 100 1112    0       0     0     0>
            , <&key_physical_attrs 100 100 1212   62       0     0     0>
            , <&key_physical_attrs 100 100 1312  112       0     0     0>
            , <&key_physical_attrs 100 100 1412  112       0     0     0>
            , <&key_physical_attrs 100 100    0  212       0     0     0>
            , <&key_physical_attrs 100 100  100  212       0     0     0>
            , <&key_physical_attrs 100 100  200  162       0     0     0>
            , <&key_physical_attrs 100 100  300  100       0     0     0>
            , <&key_physical_attrs 104 100  400  125       0     0     0>
            , <&key_physical_attrs 100 100  500  138       0     0     0>
            , <&key_physical_attrs 100 100  912  138       0     0     0>
            , <&key_physical_attrs 100 100 1012  125       0     0     0>
            , <&key_physical_attrs 100 100 1112  100       0     0     0>
            , <&key_physical_attrs 100 100 1213  162       0     0     0>
            , <&key_physical_attrs 100 100 1312  212       0     0     0>
            , <&key_physical_attrs 100 100 1412  212       0     0     0>
            , <&key_physical_attrs 100 100    0  312       0     0     0>
            , <&key_physical_attrs 100 100  100  312       0     0     0>
            , <&key_physical_attrs 100 100  200  262       0     0     0>
            , <&key_physical_attrs 100 100  300  200       0     0     0>
            , <&key_physical_attrs 100 100  400  225       0     0     0>
            , <&key_physical_attrs 100 100  500  238       0     0     0>
            , <&key_physical_attrs 100 100  912  238       0     0     0>
            , <&key_physical_attrs 100 100 1012  225       0     0     0>
            , <&key_physical_attrs 100 100 1112  200       0     0     0>
            , <&key_physical_attrs 100 100 1212  262       0     0     0>
            , <&key_physical_attrs 100 100 1312  312       0     0     0>
            , <&key_physical_attrs 100 100 1415  312       0     0     0>
            , <&key_physical_attrs 100 100    0  412       0     0     0>
            , <&key_physical_attrs 100 100  100  412       0     0     0>
            , <&key_physical_attrs 100 100  200  362       0     0     0>
            , <&key_physical_attrs 100 100  300  300       0     0     0>
            , <&key_physical_attrs 100 100  400  325       0     0     0>
            , <&key_physical_attrs 100 100  500  338       0     0     0>
            , <&key_physical_attrs 100 100  912  338       0     0     0>
            , <&key_physical_attrs 100 100 1012  325       0     0     0>
            , <&key_physical_attrs 100 100 1112  300       0     0     0>
            , <&key_physical_attrs 100 100 1212  362       0     0     0>
            , <&key_physical_attrs 100 100 1312  412       0     0     0>
            , <&key_physical_attrs 100 100 1415  412       0     0     0>
            , <&key_physical_attrs 100 100  350  472       0     0     0>
            , <&key_physical_attrs 100 100  450  472       0     0     0>
            , <&key_physical_attrs 100 100  550  472       0     0     0>
            , <&key_physical_attrs 100 100  850  472       0     0     0>
            , <&key_physical_attrs 100 100  950  472       0     0     0>
            , <&key_physical_attrs 100 100 1050  472       0     0     0>
            ;
    };
};
